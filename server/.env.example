# ── YouTube ────────────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs → YouTube Data API v3 → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here
# Your channel ID (from youtube.com/channel/XXXXX or channel settings)
YOUTUBE_CHANNEL_ID=your_channel_id_here

# ── Spotify ────────────────────────────────────────────────────────────────────
# Get from: developer.spotify.com → Create App
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Your artist ID (from open.spotify.com/artist/XXXXX)
SPOTIFY_ARTIST_ID=your_spotify_artist_id_here

# ── Instagram ──────────────────────────────────────────────────────────────────
# Get from: developers.facebook.com → My Apps → Instagram Basic Display
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
# After running the OAuth flow, paste the token returned here (or in Vercel env vars)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ── TikTok ─────────────────────────────────────────────────────────────────────
# Get from: developers.tiktok.com → Manage Apps
# NOTE: Requires TikTok app review/approval before live data works
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
# After running the OAuth flow, paste the token returned here (or in Vercel env vars)
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ── Audiomack ──────────────────────────────────────────────────────────────────
# Get from: audiomack.com/oauth-clients
AUDIOMACK_CONSUMER_KEY=your_audiomack_consumer_key_here
AUDIOMACK_CONSUMER_SECRET=your_audiomack_consumer_secret_here
# Your Audiomack profile slug (audiomack.com/YOUR_SLUG)
AUDIOMACK_SLUG=jukatha

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── OAuth CSRF ────────────────────────────────────────────────────────────────
OAUTH_STATE_SECRET=change-this-to-a-long-random-string

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
SESSION_SECRET=change-this-to-a-long-random-string
